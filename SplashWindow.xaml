<Window x:Class="WuwaIDLauncher.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Height="215" Width="460"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="0" BorderThickness="1" BorderBrush="#00f0ff" Background="#060a14">
        <Grid>
            <!-- Background flicker effect -->
            <Rectangle x:Name="flickerRect" Fill="#00f0ff" Opacity="0.02">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.01" To="0.04" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>
            
            <StackPanel Margin="20">
                <TextBlock Text="SYSTEM BOOT" FontFamily="Consolas" Foreground="#00f0ff" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                <ItemsControl x:Name="logItems" FontFamily="Consolas" FontSize="11" Foreground="#00f0ff">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="currentLine" Text="> INITIALIZING..." FontFamily="Consolas" FontSize="11" Foreground="#00f0ff"/>
                    <Border Background="#00f0ff" Width="8" Height="14" Margin="5,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.4" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </StackPanel>
            </StackPanel>
            
            <!-- Scanline overlay -->
            <Rectangle IsHitTestVisible="False">
                <Rectangle.Fill>
                    <VisualBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute">
                        <VisualBrush.Visual>
                            <Rectangle Fill="#000" Opacity="0.3" Width="1" Height="2"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Matrix rain canvas — on top so it's visible -->
            <Canvas x:Name="matrixCanvas" IsHitTestVisible="False" Opacity="0.65" ClipToBounds="True"/>
        </Grid>
    </Border>
</Window>
